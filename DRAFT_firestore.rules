rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             (request.auth.token.email.lower() == "kuteyioluwaloyevincent291@gmail.com" || 
              request.auth.token.email.lower() == "vinvaldigital291@gmail.com" ||
              request.auth.token.email.lower() == "dev@davricgroup.com");
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['slug', 'title', 'content', 'categories']) &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 500 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
             data.categories is list && data.categories.size() > 0 &&
             (data.get('status', 'published') is string) &&
             (data.get('author', '') is string && data.get('author', '').size() <= 200) &&
             (data.get('image', '') is string && data.get('image', '').size() <= 2048) &&
             (data.get('excerpt', '') is string && data.get('excerpt', '').size() <= 2048) &&
             (data.get('date', '') is string && data.get('date', '').size() <= 100);
    }

    // 1. Blog Posts Collection
    match /blogPosts/{postId} {
      // Secure list queries enforced by requiring read access
      allow read: if true;
      
      allow create: if isAdmin() && 
                      isValidBlogPost(request.resource.data) && 
                      request.resource.data.createdAt == request.time;

      allow update: if isAdmin() && 
                      isValidBlogPost(request.resource.data) && 
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.createdAt == resource.data.createdAt; // Immutable field

      allow delete: if isAdmin();
    }

    match /analytics/{eventId} {
      allow create: if request.resource.data.type in ['page_view', 'session_start'] &&
                       request.resource.data.timestamp == request.time;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['postId', 'authorName', 'content', 'createdAt']) &&
                       request.resource.data.keys().size() == 4 &&
                       request.resource.data.content is string &&
                       request.resource.data.content.size() <= 1000 &&
                       request.resource.data.authorName is string &&
                       request.resource.data.authorName.size() <= 100 &&
                       request.resource.data.createdAt == request.time;
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /contactInquiries/{inquiryId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.fullName is string && request.resource.data.fullName.size() > 0 &&
                       request.resource.data.email is string && request.resource.data.email.size() > 0 &&
                       request.resource.data.projectType is string && request.resource.data.projectType.size() > 0 &&
                       request.resource.data.message is string && request.resource.data.message.size() > 0;
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
