{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A single blog post entry",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "date": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "readTime": { "type": "string" },
        "author": { "type": "string" },
        "status": { "type": "string", "enum": ["published", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "content", "categories"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "A single tracking event like a page view",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["page_view", "session_start"] },
        "path": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "visitorId": { "type": "string" },
        "userAgent": { "type": "string" },
        "platform": { "type": "string" }
      },
      "required": ["type", "path", "timestamp", "visitorId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a blog post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorName", "content"]
    },
    "ContactInquiry": {
      "title": "Contact Inquiry",
      "description": "A submission from the contact inquiry form",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "projectType": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "projectType", "message"]
    }
  },
  "firestore": {
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    },
    "/analytics/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Tracking events for visitor analytics"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Visitor comments on blog posts"
    },
    "/contactInquiries/{inquiryId}": {
      "schema": "ContactInquiry",
      "description": "Submissions from the client/visitor contact form"
    }
  }
}
